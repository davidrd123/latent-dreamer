{:tasks
 {format {:doc "Format all source files"
          :task (shell "clojure -M:cljfmt fix src test dev trace")}
  lint {:doc "Lint with clj-kondo"
        :task (shell "clj-kondo --lint src test dev trace")}
  test {:doc "Run all tests"
        :task (shell "clojure -M:test")}
  check {:doc "Format, lint, and test"
         :depends [format lint test]}
  puppet-knows-trace
  {:doc "Write the scripted Puppet Knows benchmark trace as reporter JSON and HTML"
   :task (shell "clojure -M:trace -m daydreamer.export-trace --benchmark scripted --out out/puppet_knows_benchmark.json --render-html --html-out out/puppet_knows_benchmark.html")}
  puppet-knows-semi-trace
  {:doc "Write the semi-unscripted Puppet Knows benchmark trace as reporter JSON and HTML"
   :task (shell "clojure -M:trace -m daydreamer.export-trace --benchmark semi-unscripted --out out/puppet_knows_semi_unscripted.json --render-html --html-out out/puppet_knows_semi_unscripted.html")}
  puppet-knows-compare
  {:doc "Render scripted vs semi-unscripted Puppet Knows in one comparison HTML report"
   :depends [puppet-knows-trace puppet-knows-semi-trace]
   :task (shell "python3 ../../scope-drd/tools/daydream_trace_report.py ../out/puppet_knows_benchmark.json ../out/puppet_knows_semi_unscripted.json --label scripted --label semi-unscripted --title 'Puppet Knows: Scripted vs Semi-Unscripted' --out ../out/puppet_knows_compare.html")}
  puppet-knows-autonomous
  {:doc "Run the fixture-driven autonomous Puppet Knows trace, print summaries, and render HTML"
   :task (shell "clojure -M:trace -m daydreamer.export-trace --benchmark autonomous --cycles 12 --out out/puppet_knows_autonomous.json --render-html --html-out out/puppet_knows_autonomous.html --print-summary")}
  puppet-knows-autonomous-cognitive
  {:doc "Render a standalone cognitive playback page with embedded Puppet Knows autonomous trace data"
   :depends [puppet-knows-autonomous]
   :task (shell "python3 trace/daydreamer/render_cognitive_viz.py ../out/puppet_knows_autonomous.json --title 'Puppet Knows: Cognitive Trace Playback' --out ../out/puppet_knows_autonomous_cognitive.html")}
  graffito-miniworld-trace
  {:doc "Run the autonomous Graffito miniworld trace and render the debug canopy"
   :task (shell "clojure -M:trace -m daydreamer.export-trace --benchmark graffito-miniworld --cycles 20 --out out/graffito_miniworld.json --render-canopy --canopy-out out/graffito_miniworld_canopy.html --print-summary")}
  graffito-miniworld-trace-100
  {:doc "Run the 100-cycle Graffito miniworld trace and render the debug canopy"
   :task (shell "clojure -M:trace -m daydreamer.export-trace --benchmark graffito-miniworld --cycles 100 --out out/graffito_miniworld_100.json --render-canopy --canopy-out out/graffito_miniworld_100_canopy.html --print-summary")}
  typed-issue-entry
  {:doc "Run the first bounded typed issue-entry experiment and print its summary"
   :task (shell "clojure -M -e '(require (quote [daydreamer.benchmarks.typed-issue-entry :as tie])) (prn (:summary (tie/run-mock-issue-entry)))'")}
  dream
  {:doc "Alias for the autonomous Puppet Knows dream trace"
   :depends [puppet-knows-autonomous]}
  dream-viz
  {:doc "Alias for the autonomous cognitive playback visualizer"
   :depends [puppet-knows-autonomous-cognitive]}
  dream-with-director
  {:doc "Run Puppet Knows with a live Director loop using gemini-3-flash-preview. Pass --mock-director for deterministic local mode."
   :task (let [args (apply str (interpose " " *command-line-args*))
               command (str "clojure -M:trace -m daydreamer.export-trace "
                            "--benchmark autonomous-director "
                            "--director-model gemini-3-flash-preview "
                            "--cycles 12 "
                            "--out out/puppet_knows_with_director.json "
                            "--render-html "
                            "--html-out out/puppet_knows_with_director.html "
                            "--print-summary "
                            args)]
           (shell command))}
  dream-with-director-pro
  {:doc "Run Puppet Knows with a live Director loop using gemini-3.1-pro-preview."
   :task (let [args (apply str (interpose " " *command-line-args*))
               command (str "clojure -M:trace -m daydreamer.export-trace "
                            "--benchmark autonomous-director "
                            "--director-model gemini-3.1-pro-preview "
                            "--cycles 12 "
                            "--out out/puppet_knows_with_director_pro.json "
                            "--render-html "
                            "--html-out out/puppet_knows_with_director_pro.html "
                            "--print-summary "
                            args)]
           (shell command))}
  dream-with-director-viz
  {:doc "Render a standalone cognitive playback page for the existing Director-in-loop dream trace"
   :depends [dream-with-director]
   :task (shell "python3 trace/daydreamer/render_cognitive_viz.py ../out/puppet_knows_with_director.json --title 'Puppet Knows: Director-In-Loop Playback' --out ../out/puppet_knows_with_director_cognitive.html")}
  dream-with-director-pro-viz
  {:doc "Render a standalone cognitive playback page for the Pro Director trace"
   :depends [dream-with-director-pro]
   :task (shell "python3 trace/daydreamer/render_cognitive_viz.py ../out/puppet_knows_with_director_pro.json --title 'Puppet Knows: Pro Director Playback' --out ../out/puppet_knows_with_director_pro_cognitive.html")}
  dream-with-mock-director
  {:doc "Run Puppet Knows with the deterministic mock Director"
   :task (shell "clojure -M:trace -m daydreamer.export-trace --benchmark autonomous-mock-director --cycles 12 --out out/puppet_knows_with_mock_director.json --render-html --html-out out/puppet_knows_with_mock_director.html --print-summary")}
  dream-with-mock-director-viz
  {:doc "Render a standalone cognitive playback page for the mock-Director trace"
   :depends [dream-with-mock-director]
   :task (shell "python3 trace/daydreamer/render_cognitive_viz.py ../out/puppet_knows_with_mock_director.json --title 'Puppet Knows: Mock Director Playback' --out ../out/puppet_knows_with_mock_director_cognitive.html")}
  dream-with-mock-director-compare
  {:doc "Compare baseline autonomous Puppet Knows against the mock-Director run"
   :depends [puppet-knows-autonomous dream-with-mock-director]
   :task (shell "python3 ../../scope-drd/tools/daydream_trace_report.py ../out/puppet_knows_autonomous.json ../out/puppet_knows_with_mock_director.json --label baseline --label mock-director --title 'Puppet Knows: Baseline vs Mock Director' --out ../out/puppet_knows_with_mock_director_compare.html")}
  arctic-trace
  {:doc "Write the scripted Arctic Expedition benchmark trace as reporter JSON and HTML"
   :task (shell "clojure -M:trace -m daydreamer.export-trace --benchmark arctic-scripted --out out/arctic_expedition_benchmark.json --render-html --html-out out/arctic_expedition_benchmark.html")}
  arctic-semi-trace
  {:doc "Write the semi-unscripted Arctic Expedition benchmark trace as reporter JSON and HTML"
   :task (shell "clojure -M:trace -m daydreamer.export-trace --benchmark arctic-semi-unscripted --out out/arctic_expedition_semi_unscripted.json --render-html --html-out out/arctic_expedition_semi_unscripted.html")}
  arctic-compare
  {:doc "Render scripted vs semi-unscripted Arctic Expedition in one comparison HTML report"
   :depends [arctic-trace arctic-semi-trace]
   :task (shell "python3 ../../scope-drd/tools/daydream_trace_report.py ../out/arctic_expedition_benchmark.json ../out/arctic_expedition_semi_unscripted.json --label scripted --label semi-unscripted --title 'Arctic Expedition: Scripted vs Semi-Unscripted' --out ../out/arctic_expedition_compare.html")}
  zone-trace
  {:doc "Write the scripted Stalker Zone benchmark trace as reporter JSON and HTML"
   :task (shell "clojure -M:trace -m daydreamer.export-trace --benchmark zone-scripted --out out/stalker_zone_benchmark.json --render-html --html-out out/stalker_zone_benchmark.html")}
  zone-semi-trace
  {:doc "Write the semi-unscripted Stalker Zone benchmark trace as reporter JSON and HTML"
   :task (shell "clojure -M:trace -m daydreamer.export-trace --benchmark zone-semi-unscripted --out out/stalker_zone_semi_unscripted.json --render-html --html-out out/stalker_zone_semi_unscripted.html")}
  zone-compare
  {:doc "Render scripted vs semi-unscripted Stalker Zone in one comparison HTML report"
   :depends [zone-trace zone-semi-trace]
   :task (shell "python3 ../../scope-drd/tools/daydream_trace_report.py ../out/stalker_zone_benchmark.json ../out/stalker_zone_semi_unscripted.json --label scripted --label semi-unscripted --title 'Stalker Zone: Scripted vs Semi-Unscripted' --out ../out/stalker_zone_compare.html")}
  nrepl {:doc "Start nREPL on port 7888"
         :task (clojure "-M:nrepl")}}}
