#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

if command -v uv >/dev/null 2>&1; then
  exec uv run --project "$ROOT_DIR" python -m daydream_vision.cli "$@"
fi

if [[ -x "$ROOT_DIR/.venv-daydream-vision/bin/python" ]]; then
  exec "$ROOT_DIR/.venv-daydream-vision/bin/python" -m daydream_vision.cli "$@"
fi

exec python3 -m daydream_vision.cli "$@"
